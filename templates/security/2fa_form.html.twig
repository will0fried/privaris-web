{% extends 'base.html.twig' %}

{% block title %}Vérification en deux étapes · Privaris{% endblock %}

{% block body %}
    <section class="section">
        <div class="container-narrow max-w-sm">
            <h1 class="text-h2 mb-2 text-center">Vérification en 2 étapes</h1>
            <p class="text-fog text-sm text-center mb-8">Entrez le code à 6 chiffres généré par votre application d'authentification.</p>

            {% if authenticationError %}
                <div class="alert-block mb-6 text-alert"><p>{{ authenticationError|trans(authenticationErrorData, 'SchebTwoFactorBundle') }}</p></div>
            {% endif %}

            <form method="post" action="{{ checkPathUrl ?? path('2fa_login_check') }}" class="space-y-4">
                <div>
                    <label for="_auth_code" class="sr-only">Code 2FA</label>
                    <input type="text" name="{{ authCodeParameterName }}" id="_auth_code" required autofocus inputmode="numeric" pattern="[0-9]*"
                           class="w-full px-4 py-3 text-center text-2xl tracking-[0.5em] rounded-xl border border-mist focus:border-navy focus:outline-none"
                           placeholder="······" maxlength="6">
                </div>
                {% if displayTrustedOption %}
                <label class="flex items-center gap-2 text-sm text-fog">
                    <input type="checkbox" name="{{ trustedParameterName }}" class="accent-navy">
                    Faire confiance à cet appareil pendant 60 jours
                </label>
                {% endif %}
                <button type="submit" class="btn-primary w-full justify-center">Valider</button>
            </form>

            <form method="post" action="{{ logoutPath }}" class="mt-8 text-center">
                <button type="submit" class="text-sm text-fog underline hover:text-navy">Annuler et se déconnecter</button>
            </form>
        </div>
    </section>
{% endblock %}
