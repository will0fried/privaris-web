{% extends 'base.html.twig' %}

{% block title %}Connexion · Privaris{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
<div class="wrap">
    <div style="max-width:380px;margin:72px auto 120px;">
        <p class="ey">Accès réservé</p>
        <h1 style="font-size:34px;letter-spacing:-.02em;margin:0 0 26px;">Connexion</h1>

        {% if error %}
            <div class="form-flash form-flash--err">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" class="form-pv">
            <div>
                <label for="email">Email</label>
                <input type="email" name="email" id="email" value="{{ last_username }}" required autofocus autocomplete="username">
            </div>
            <div style="margin-top:18px;">
                <label for="password">Mot de passe</label>
                <input type="password" name="password" id="password" required autocomplete="current-password">
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="pv-btn" style="width:100%;justify-content:center;margin-top:24px;">Se connecter</button>
        </form>

        <p style="font-family:var(--font-mono);font-size:11px;letter-spacing:.04em;color:var(--color-dim);margin-top:24px;text-align:center;">
            Accès réservé aux rédacteurs et administrateurs de Privaris.
        </p>
    </div>
</div>
{% endblock %}
