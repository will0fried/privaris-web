{% extends 'base.html.twig' %}

{% block title %}Connexion · Privaris{% endblock %}

{% block body %}
    <section class="section">
        <div class="container-narrow max-w-sm">
            <h1 class="text-h2 mb-6 text-center">Connexion</h1>

            {% if error %}
                <div class="alert-block mb-6 text-alert"><p>{{ error.messageKey|trans(error.messageData, 'security') }}</p></div>
            {% endif %}

            <form method="post" class="space-y-4">
                <div>
                    <label for="email" class="block text-sm font-medium text-navy mb-1.5">Email</label>
                    <input type="email" name="email" id="email" value="{{ last_username }}" required autofocus autocomplete="username"
                           class="w-full px-4 py-3 rounded-xl border border-mist focus:border-navy focus:outline-none transition">
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-navy mb-1.5">Mot de passe</label>
                    <input type="password" name="password" id="password" required autocomplete="current-password"
                           class="w-full px-4 py-3 rounded-xl border border-mist focus:border-navy focus:outline-none transition">
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn-primary w-full justify-center">Se connecter</button>
            </form>

            <p class="text-xs text-fog mt-6 text-center">
                Accès réservé aux rédacteurs et administrateurs de Privaris.
            </p>
        </div>
    </section>
{% endblock %}
