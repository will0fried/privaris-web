{% extends 'base.html.twig' %}

{% block title %}Page introuvable · Privaris{% endblock %}

{% block body %}
    <section class="hero-xl has-decor">
        <div class="container-wide">
            <div class="max-w-3xl">
                <p class="eyebrow">Erreur 404</p>
                <h1 class="text-hero text-balance animate-slide-up">
                    L'adresse vous <span class="text-navy">ment</span>.<br>
                    Ça tombe bien, on sait faire.
                </h1>
                <p class="text-lg md:text-xl text-fog leading-relaxed max-w-2xl mt-10">
                    Cette page n'existe plus, n'a jamais existé, ou le lien qui
                    vous a amené ici est cassé. Ça arrive. Ce n'est pas vous, ce
                    n'est pas grave, et il y a quand même de quoi faire.
                </p>

                <div class="flex flex-wrap items-center gap-4 mt-10">
                    <a href="{{ path('app_home') }}" class="btn-primary">Retour à l'accueil</a>
                    <a href="{{ path('app_blog_index') }}" class="btn-link">
                        Voir les articles
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                    </a>
                </div>

                {# Indicateur technique discret #}
                <div class="mt-16 pt-8 border-t border-mist">
                    <p class="font-mono text-[11px] uppercase tracking-[0.15em] text-fog flex items-center gap-3">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-alert" aria-hidden="true"></span>
                        HTTP 404 · Not Found · Ressource introuvable
                    </p>
                </div>
            </div>
        </div>
    </section>

    {# Rassurer avec une direction #}
    <section class="section border-t border-mist">
        <div class="container-wide">
            <div class="split-section">
                <div class="split-section__label">
                    <p class="eyebrow">Trois portes qui marchent</p>
                </div>
                <div class="split-section__body">
                    <ul class="divide-y divide-mist">
                        <li class="py-5 flex items-start justify-between gap-6">
                            <div>
                                <p class="font-semibold text-ink mb-1">Lire les derniers articles</p>
                                <p class="text-fog text-sm leading-relaxed">Les arnaques qui tournent en ce moment, un sujet à la fois.</p>
                            </div>
                            <a href="{{ path('app_blog_index') }}" class="btn-link text-sm whitespace-nowrap">Les articles →</a>
                        </li>
                        <li class="py-5 flex items-start justify-between gap-6">
                            <div>
                                <p class="font-semibold text-ink mb-1">Glisser un écouteur</p>
                                <p class="text-fog text-sm leading-relaxed">Trois minutes, un piège, tous les mardis matin.</p>
                            </div>
                            <a href="{{ path('app_podcast_index') }}" class="btn-link text-sm whitespace-nowrap">Le podcast →</a>
                        </li>
                        <li class="py-5 flex items-start justify-between gap-6">
                            <div>
                                <p class="font-semibold text-ink mb-1">Signaler ce lien cassé</p>
                                <p class="text-fog text-sm leading-relaxed">Si cette page aurait dû exister, on veut le savoir.</p>
                            </div>
                            <a href="{{ path('app_contact') }}" class="btn-link text-sm whitespace-nowrap">Nous écrire →</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
