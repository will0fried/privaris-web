{% extends 'base.html.twig' %}

{% block title %}Contact · Écrire à Privaris{% endblock %}
{% block description %}Une question, une idée de manip, une erreur à signaler, une faille sur le site. Tout arrive dans la même boîte. Je lis, je réponds sous 48 h.{% endblock %}

{% block body %}
<div class="wrap wrap--tight">

    {# ========= HÉROS ========= #}
    <header class="ab-hero">
        <p class="ey">Contact</p>
        <h1>Une question ? Écris-moi.</h1>
        <p class="ab-lede">Une idée de manip, une remarque, une erreur repérée, une faille sur le site. Tout arrive dans la même boîte. Je lis, je réponds, et parfois ça devient l'entrée de la semaine.</p>
        <div class="ab-meta">
            <span>réponse sous 48 h</span>
            <span>lun → ven</span>
            <span>fr · en</span>
        </div>
    </header>

    {# ========= CANAUX ========= #}
    <section>
        <p class="kicker">Trois portes d'entrée</p>
        <div style="display:flex;flex-direction:column;gap:14px;">
            <a href="mailto:redaction@privaris.fr" style="display:block;border:1px solid var(--color-line);border-radius:14px;padding:24px;background:linear-gradient(180deg,var(--color-panel),transparent);text-decoration:none;">
                <div style="display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:baseline;">
                    <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;color:var(--color-cyan);">01 · ÉDITORIAL</span>
                    <span style="font-family:var(--font-mono);font-size:12px;color:var(--color-muted);">redaction@privaris.fr</span>
                </div>
                <p style="margin:12px 0 0;color:var(--color-muted);font-size:15px;">Une question, une idée de sujet, une erreur à me signaler dans une entrée.</p>
            </a>
            <a href="mailto:presse@privaris.fr" style="display:block;border:1px solid var(--color-line);border-radius:14px;padding:24px;background:linear-gradient(180deg,var(--color-panel),transparent);text-decoration:none;">
                <div style="display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:baseline;">
                    <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;color:var(--color-cyan);">02 · PRESSE & ATELIERS</span>
                    <span style="font-family:var(--font-mono);font-size:12px;color:var(--color-muted);">presse@privaris.fr</span>
                </div>
                <p style="margin:12px 0 0;color:var(--color-muted);font-size:15px;">Interview, intervention, atelier. Zéro contenu sponsorisé, ça ne bougera pas.</p>
            </a>
            <a href="mailto:security@privaris.fr" style="display:block;border:1px solid var(--color-line);border-radius:14px;padding:24px;background:linear-gradient(180deg,var(--color-panel),transparent);text-decoration:none;">
                <div style="display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:baseline;">
                    <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;color:var(--color-red);">03 · SÉCURITÉ</span>
                    <span style="font-family:var(--font-mono);font-size:12px;color:var(--color-muted);">security@privaris.fr</span>
                </div>
                <p style="margin:12px 0 0;color:var(--color-muted);font-size:15px;">Une faille repérée sur privaris.fr ? Disclosure responsable, reconnaissance nominative si tu veux.</p>
            </a>
        </div>
    </section>

    {# ========= FORMULAIRE ========= #}
    <section id="form">
        <p class="kicker">Le formulaire</p>
        <div class="form-pv">
            {% for msg in app.flashes('success') %}<div class="form-flash form-flash--ok">{{ msg }}</div>{% endfor %}
            {% for msg in app.flashes('error') %}<div class="form-flash form-flash--err">{{ msg }}</div>{% endfor %}

            {{ form_start(form) }}
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;">
                    <div>{{ form_label(form.name) }}{{ form_widget(form.name) }}{{ form_errors(form.name) }}</div>
                    <div>{{ form_label(form.email) }}{{ form_widget(form.email, {attr: {autocomplete: 'email'}}) }}{{ form_errors(form.email) }}</div>
                </div>
                <div style="margin-top:18px;">{{ form_label(form.subject) }}{{ form_widget(form.subject) }}{{ form_errors(form.subject) }}</div>
                <div style="margin-top:18px;">{{ form_label(form.message) }}{{ form_widget(form.message, {attr: {rows: 5}}) }}{{ form_errors(form.message) }}</div>

                <div style="position:absolute;left:-9999px;" aria-hidden="true">{{ form_row(form.website) }}</div>

                <div style="display:flex;align-items:flex-start;gap:10px;margin-top:20px;">
                    {{ form_widget(form.consent, {attr: {style: 'margin-top:3px;accent-color:#5BE7C4;'}}) }}
                    {{ form_label(form.consent, null, {label_attr: {style: 'text-transform:none;font-family:var(--font-sans);font-size:13px;letter-spacing:0;color:var(--color-muted);margin:0;'}}) }}
                </div>
                {{ form_errors(form.consent) }}

                <div style="margin-top:24px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                    <button type="submit" class="pv-btn">Envoyer le message</button>
                    <span class="form-note">En envoyant, tu acceptes la <a href="{{ path('app_privacy') }}" style="color:var(--color-muted);text-decoration:underline;">politique de confidentialité</a>.</span>
                </div>
            {{ form_end(form) }}
        </div>
    </section>

</div>
{% endblock %}
