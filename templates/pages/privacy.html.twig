{% extends 'base.html.twig' %}

{% block title %}Politique de confidentialité · Privaris{% endblock %}

{% block body %}
    {# ========= HEADER ========= #}
    <section class="hero-xl has-decor">
        <div class="container-wide">
            <p class="eyebrow animate-fade-in">Confidentialité</p>
            <h1 class="text-hero text-balance max-w-5xl animate-slide-up">
                Vos données, <span class="text-navy">au minimum</span>.
            </h1>
            <p class="text-lg md:text-xl text-fog leading-relaxed max-w-2xl mt-10">
                Privaris ne traite que ce qui est strictement nécessaire au fonctionnement du site
                et à la livraison des contenus auxquels vous vous inscrivez.
            </p>
            <p class="text-sm text-fog mt-8">
                Dernière mise à jour&nbsp;: {{ "now"|format_datetime(pattern='d MMMM yyyy', locale='fr') }}
            </p>
        </div>
    </section>

    {# ========= CORPS + SOMMAIRE ========= #}
    <section class="pb-24 md:pb-32 border-t border-mist pt-16 md:pt-20">
        <div class="container-wide">
            <div class="grid lg:grid-cols-3 gap-10 lg:gap-14 items-start">

                {# --- Corps --- #}
                <div class="lg:col-span-2 max-w-prose-narrow">
                    <div class="prose-privaris">
                        <h2 id="responsable">Responsable du traitement</h2>
                        <p>
                            Privaris · contact : <a href="{{ path('app_contact') }}">formulaire</a>.
                        </p>

                        <h2 id="donnees">Données collectées</h2>
                        <ul>
                            <li><strong>Newsletter</strong> : email (obligatoire), prénom (optionnel), horodatage, IP d'inscription,
                                source de l'inscription (page d'origine). Base légale : <em>consentement</em> (art. 6.1.a RGPD).</li>
                            <li><strong>Formulaire de contact</strong> : nom, email, sujet, message. Base légale : <em>intérêt légitime</em>
                                (répondre à votre demande) et <em>consentement</em> pour le traitement du message.</li>
                            <li><strong>Logs serveur</strong> : IP, User-Agent, URL, horodatage. Conservés 90 jours max. Base légale :
                                <em>intérêt légitime</em> (sécurité du site, détection d'abus).</li>
                        </ul>

                        <h2 id="conservation">Durées de conservation</h2>
                        <ul>
                            <li>Newsletter : jusqu'à la désinscription, puis purgé sous 30 jours.</li>
                            <li>Messages de contact : 1 an.</li>
                            <li>Logs d'audit sécurité : 90 jours.</li>
                        </ul>

                        <h2 id="sous-traitants">Sous-traitants</h2>
                        <ul>
                            <li><strong>PlanetHoster</strong> : hébergement (Canada/France selon offre).</li>
                            <li><strong>Brevo</strong> (ex-Sendinblue) : envoi de la newsletter (données hébergées en UE, SaaS France).</li>
                        </ul>

                        <h2 id="cookies">Cookies</h2>
                        <p>
                            Privaris utilise uniquement des <strong>cookies strictement nécessaires</strong>
                            au fonctionnement du site (session administrateur, protection CSRF). Aucun cookie
                            publicitaire, aucun traceur tiers, pas de Google Analytics.
                        </p>

                        <h2 id="droits">Vos droits</h2>
                        <p>
                            Conformément au RGPD et à la loi Informatique et Libertés, vous disposez d'un droit
                            d'accès, de rectification, d'effacement, de limitation, d'opposition et de portabilité.
                            Pour les exercer, écrivez-nous via le <a href="{{ path('app_contact') }}">formulaire de contact</a>.
                        </p>
                        <p>
                            Vous pouvez également introduire une réclamation auprès de la <a href="https://www.cnil.fr" target="_blank" rel="noopener">CNIL</a>.
                        </p>
                    </div>
                </div>

                {# --- Sommaire + résumé --- #}
                <aside class="lg:col-span-1 lg:pl-8 lg:border-l border-mist lg:sticky lg:top-24 space-y-8"
                       aria-label="Sommaire">

                    <nav>
                        <p class="text-xs uppercase tracking-[0.2em] text-fog mb-3">Sommaire</p>
                        <ol class="space-y-2 text-sm">
                            <li><a href="#responsable" class="no-underline text-ink hover:text-navy">1. Responsable du traitement</a></li>
                            <li><a href="#donnees" class="no-underline text-ink hover:text-navy">2. Données collectées</a></li>
                            <li><a href="#conservation" class="no-underline text-ink hover:text-navy">3. Durées de conservation</a></li>
                            <li><a href="#sous-traitants" class="no-underline text-ink hover:text-navy">4. Sous-traitants</a></li>
                            <li><a href="#cookies" class="no-underline text-ink hover:text-navy">5. Cookies</a></li>
                            <li><a href="#droits" class="no-underline text-ink hover:text-navy">6. Vos droits</a></li>
                        </ol>
                    </nav>

                    {# Résumé privacy-friendly #}
                    <div class="card-link">
                        <p class="text-xs uppercase tracking-[0.2em] text-fog mb-3">En résumé</p>
                        <ul class="space-y-2 text-sm text-ink">
                            <li class="flex items-start gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-navy flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                                <span>Aucun traceur publicitaire</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-navy flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                                <span>Pas de Google Analytics</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-navy flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                                <span>Désinscription en un clic</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-navy flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                                <span>Hébergement FR/UE</span>
                            </li>
                        </ul>
                    </div>

                    <div>
                        <p class="text-xs uppercase tracking-[0.2em] text-fog mb-3">Une question&nbsp;?</p>
                        <a href="{{ path('app_contact') }}" class="btn-link text-xs">
                            Nous écrire
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                        </a>
                    </div>

                </aside>
            </div>
        </div>
    </section>
{% endblock %}
