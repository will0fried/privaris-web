{% extends 'base.html.twig' %}

{% block title %}À propos · Privaris, le carnet de labo de W.{% endblock %}
{% block description %}Privaris, c'est Mon Labo : j'apprends la cybersécurité en public, par la pratique. Qui je suis, comment je bosse, pourquoi il n'y a ni pub ni traceur.{% endblock %}

{% block body %}
<div class="wrap wrap--tight">

    {# ========= HÉROS ========= #}
    <header class="ab-hero">
        <p class="ey">À propos</p>
        <h1>J'apprends la cyber. En public, sans filtre.</h1>
        <p class="ab-lede">Salarié le jour, en Master de cybersécurité le soir. Privaris, c'est mon carnet de labo ouvert. J'y montre ce que je monte, ce que je casse, et ce que je rate.</p>
        <div class="ab-meta">
            <span>Master en cours</span>
            <span>en poste</span>
            <span>depuis {{ stats.firstDate ? stats.firstDate|date('Y') : "now"|date('Y') }}</span>
        </div>
    </header>

    <div class="ab-statement">
        <p>On retient mieux ce qu'on explique. <span class="q">Et les tutos parfaits cachent toujours les trois heures de galère. Ici, les galères restent.</span></p>
    </div>

    {# ========= LA MÉTHODE ========= #}
    <section>
        <p class="kicker">La méthode, à chaque entrée</p>
        <div class="m-steps">
            <div class="m-step"><div class="n">01</div><h3>Objectif</h3><p>Ce que je veux comprendre, en une phrase.</p></div>
            <div class="m-step"><div class="n">02</div><h3>Protocole</h3><p>Les étapes exactes, les vraies commandes.</p></div>
            <div class="m-step"><div class="n">03</div><h3>Observations</h3><p>Ce qui se passe, y compris l'inattendu.</p></div>
            <div class="m-step"><div class="n">04</div><h3>Ce que j'en retiens</h3><p>La leçon, et la prochaine question.</p></div>
        </div>
    </section>

    {# ========= ICI / PAS ICI ========= #}
    <section class="ct">
        <div class="ct-col yes">
            <h4>Ce que tu trouveras ici</h4>
            <ul>
                <li>Des manips reproductibles chez toi.</li>
                <li>Les vraies commandes, pas des captures floues.</li>
                <li>Les plantages, assumés et expliqués.</li>
            </ul>
        </div>
        <div class="ct-col no">
            <h4>Ce que tu n'y trouveras pas</h4>
            <ul>
                <li>Du hacking en 5 minutes chrono.</li>
                <li>Du jargon pour faire joli.</li>
                <li>Des cours recopiés sans les avoir testés.</li>
            </ul>
        </div>
    </section>

    {# ========= COMMENT JE BOSSE ========= #}
    <section>
        <p class="kicker">Comment je bosse</p>
        <ol class="method-list">
            <li><span class="mn">01</span><div><h3>Reproductible</h3><p>Ce que je montre, tu peux le refaire : commandes, configs, versions. La preuve, c'est que ça tourne aussi chez toi.</p></div></li>
            <li><span class="mn">02</span><div><h3>Sources citées</h3><p>Les sources sont liées, avec la date. Si une donnée n'est pas vérifiable publiquement, je le dis.</p></div></li>
            <li><span class="mn">03</span><div><h3>Les plantages restent</h3><p>Quand ça casse, je le laisse dans le récit. La soirée où rien ne marche apprend plus qu'un tuto parfait.</p></div></li>
            <li><span class="mn">04</span><div><h3>Corrections signalées</h3><p>Une erreur repérée est corrigée, et la correction est datée en bas d'entrée. Jamais en douce.</p></div></li>
        </ol>
    </section>

    {# ========= EN CHIFFRES ========= #}
    <section>
        <p class="kicker">En chiffres</p>
        <div class="home-stats">
            <div class="stat"><div class="n">{{ '%02d'|format(stats.articles|default(0)) }}</div><div class="l">entrées publiées</div></div>
            <div class="stat"><div class="n">{{ '%02d'|format(stats.episodes|default(0)) }}</div><div class="l">épisodes podcast</div></div>
            <div class="stat red"><div class="n">0</div><div class="l">pub · traceur</div></div>
        </div>
    </section>

    {# ========= FAQ (+ JSON-LD) ========= #}
    <section>
        <p class="kicker">Questions fréquentes</p>
        <div class="faq">
            <details>
                <summary><h3>Privaris est-il gratuit ?</h3><span class="pm" aria-hidden="true">+</span></summary>
                <p>Oui, intégralement. Le journal, les writeups, les décryptages : tout est gratuit, rien derrière un mur payant.</p>
            </details>
            <details>
                <summary><h3>À qui s'adresse le site ?</h3><span class="pm" aria-hidden="true">+</span></summary>
                <p>À ceux qui apprennent la cyber, ou veulent la comprendre : débutants, reconvertis, étudiants, curieux. En public, sans bullshit.</p>
            </details>
            <details>
                <summary><h3>Qui écrit ?</h3><span class="pm" aria-hidden="true">+</span></summary>
                <p>W., qui apprend la cybersécurité en public, salarié le jour, en Master le soir. Pas d'équipe ni d'experts invités : juste moi, qui documente ce que je pratique.</p>
            </details>
            <details>
                <summary><h3>Pourquoi pas de publicité ?</h3><span class="pm" aria-hidden="true">+</span></summary>
                <p>Parce que la pub en ligne colle des traceurs partout, soit l'inverse de ce qu'on apprend ici. Le site reste indépendant, sans pub et sans traceur.</p>
            </details>
            <details>
                <summary><h3>Comment proposer un sujet ou une correction ?</h3><span class="pm" aria-hidden="true">+</span></summary>
                <p>Une idée de manip, une remarque, une erreur repérée ? Écris-moi via la <a href="{{ path('app_contact') }}">page contact</a>.</p>
            </details>
        </div>
    </section>

    {# ========= QUI ÉCRIT ========= #}
    <div class="who" style="margin-top:60px;">
        <span class="av">W.</span>
        <p><b>Qui écrit ?</b> W., un type qui apprend la cyber et qui préfère le montrer plutôt que faire semblant de tout savoir.</p>
    </div>
    <div class="cta">
        <a class="pv-btn" href="{{ path('app_home') }}">→ commence par le radar</a>
        <a class="pv-btn pv-btn--ghost" href="{{ path('app_blog_index') }}">le journal</a>
        <a class="pv-btn pv-btn--ghost" href="{{ path('app_contact') }}">me contacter</a>
    </div>

    {% include 'components/_newsletter.html.twig' with {source: 'about'} only %}
</div>

<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {"@type": "Question", "name": "Privaris est-il gratuit ?", "acceptedAnswer": {"@type": "Answer", "text": "Oui, intégralement. Le journal, les writeups, les décryptages : tout est gratuit, rien derrière un mur payant."}},
        {"@type": "Question", "name": "À qui s'adresse le site ?", "acceptedAnswer": {"@type": "Answer", "text": "À ceux qui apprennent la cybersécurité, ou veulent la comprendre : débutants, personnes en reconversion, étudiants, curieux. En public, en français, sans bullshit."}},
        {"@type": "Question", "name": "Qui écrit les articles ?", "acceptedAnswer": {"@type": "Answer", "text": "W., qui apprend la cybersécurité en public, salarié le jour, en Master le soir. Pas d'équipe ni d'experts invités : juste quelqu'un qui documente ce qu'il pratique, plantages compris."}},
        {"@type": "Question", "name": "Pourquoi pas de publicité sur Privaris ?", "acceptedAnswer": {"@type": "Answer", "text": "Parce que la publicité en ligne entraîne presque toujours des traceurs, soit l'inverse de ce qu'on apprend ici. Le site est indépendant, sans pub et sans traceur, et le restera."}},
        {"@type": "Question", "name": "Comment proposer un sujet ou une correction ?", "acceptedAnswer": {"@type": "Answer", "text": "Par la page contact, ou en écrivant à redaction@privaris.fr. Une idée de manip, une remarque, une erreur repérée : c'est bienvenu."}}
    ]
}
</script>
{% endblock %}
