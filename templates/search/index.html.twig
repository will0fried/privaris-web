{% extends 'base.html.twig' %}

{% set currentPage = pagination.page|default(1) %}
{% set totalPages  = pagination.pages|default(1) %}
{% set total       = pagination.total|default(0) %}

{% block title %}
    {%- if hasQuery -%}
        « {{ query }} » · Recherche · Privaris{% if currentPage > 1 %} · Page {{ currentPage }}{% endif %}
    {%- else -%}
        Rechercher · Privaris
    {%- endif -%}
{% endblock %}

{% block description %}Cherche dans le journal Privaris : labs, writeups, décryptages, tout ce que j'apprends en public en cybersécurité.{% endblock %}
{% block robots %}noindex, follow{% endblock %}

{% block body %}
<div class="wrap wrap--mid">

    <header class="j-head">
        <p class="ey">Recherche</p>
        <h1>
            {% if hasQuery %}{{ total }} résultat{{ total > 1 ? 's' : '' }} <span style="color:var(--color-muted);">pour « {{ query }} »</span>
            {% else %}Que cherches-tu ?{% endif %}
        </h1>

        <form action="{{ path('app_search') }}" method="get" role="search" aria-label="Recherche"
              style="margin-top:28px;display:flex;gap:10px;max-width:560px;flex-wrap:wrap;">
            <label for="search-input" class="sr-only">Mot-clé</label>
            <input id="search-input" type="search" name="q" value="{{ query }}"
                   placeholder="nmap, Proxmox, Kali, writeup…" required minlength="{{ minLength }}" maxlength="100"
                   autocomplete="off" autofocus
                   style="flex:1;min-width:220px;background:#0A1120;border:1px solid var(--color-line);border-radius:10px;padding:13px 16px;color:var(--color-text);font-family:var(--font-sans);font-size:15px;">
            <button type="submit" class="pv-btn">Rechercher</button>
        </form>

        {% if tooShort %}
            <p style="margin-top:14px;font-size:13px;color:var(--color-muted);" role="status">Au moins {{ minLength }} caractères, s'il te plaît.</p>
        {% endif %}
    </header>

    {% if hasQuery and articles|length > 0 %}
        <div class="ledger" style="margin-top:20px;">
            {% for a in articles %}
                <a class="led-row" href="{{ path('app_blog_show', {slug: a.slug}) }}">
                    <span class="num">{{ '%02d'|format(loop.index) }}</span>
                    <span class="date">{{ a.publishedAt ? a.publishedAt|date('d.m') : '—' }}</span>
                    <span class="ttl">{{ a.title }}</span>
                    <span class="cat">{{ a.category ? a.category.name|upper : 'LABS' }}</span>
                    <span class="rt">{{ a.readingMinutes }} min</span>
                </a>
            {% endfor %}
        </div>

        {% if pagination is defined and totalPages > 1 %}
            {% include 'components/_pagination.html.twig' with {pagination: pagination, route: 'app_search', routeParams: {q: query}} only %}
        {% endif %}

    {% elseif hasQuery %}
        <div style="padding:60px 0;text-align:center;max-width:34rem;margin:0 auto;">
            <p style="font-size:22px;font-weight:600;font-family:var(--font-disp);margin:0 0 10px;">Aucune entrée trouvée.</p>
            <p style="color:var(--color-muted);line-height:1.6;margin:0 0 24px;">Rien sur « {{ query }} » pour l'instant. Essaie un terme plus large, ou parcours le journal.</p>
            <a href="{{ path('app_blog_index') }}" class="pv-btn">Tout le journal</a>
        </div>

    {% else %}
        <div style="padding:30px 0 0;">
            <p class="kicker">Pistes</p>
            <div style="display:flex;flex-wrap:wrap;gap:10px;">
                {% set suggestions = ['homelab', 'nmap', 'Proxmox', 'Kali', 'writeup', 'réseau', 'Linux', 'défense'] %}
                {% for s in suggestions %}
                    <a class="j-chip" href="{{ path('app_search', {q: s}) }}">{{ s }}</a>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {% include 'components/_newsletter.html.twig' with {source: 'search'} only %}
</div>
{% endblock %}
