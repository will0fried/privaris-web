{% extends 'base.html.twig' %}

{% set currentPage = pagination.page|default(1) %}
{% set totalPages  = pagination.pages|default(1) %}

{% block title %}
    {%- if activeCategory is defined -%}
        {{ activeCategory.name }} · Privaris{% if currentPage > 1 %} · Page {{ currentPage }}{% endif %}
    {%- elseif activeTag is defined -%}
        #{{ activeTag.name }} · Privaris{% if currentPage > 1 %} · Page {{ currentPage }}{% endif %}
    {%- else -%}
        Le journal · Privaris{% if currentPage > 1 %} · Page {{ currentPage }}{% endif %}
    {%- endif -%}
{% endblock %}

{% block description %}
    {%- if activeCategory is defined and activeCategory.description -%}
        {{ activeCategory.description }}
    {%- elseif activeTag is defined -%}
        Les entrées du journal filtrées sur #{{ activeTag.name }} : labs, writeups et décryptages, en public.
    {%- else -%}
        Le journal de Privaris : chaque entrée est une manip réelle, documentée de bout en bout. Réussites comme plantages.
    {%- endif -%}
{% endblock %}

{% block head_extra %}
    {% if pagination is defined %}
        {% set pageParams = app.request.attributes.get('_route_params')|default({}) %}
        {% if currentPage > 1 %}
            <link rel="prev" href="{{ url(app.request.attributes.get('_route'), pageParams|merge({page: currentPage - 1})) }}">
        {% endif %}
        {% if currentPage < totalPages %}
            <link rel="next" href="{{ url(app.request.attributes.get('_route'), pageParams|merge({page: currentPage + 1})) }}">
        {% endif %}
    {% endif %}
{% endblock %}

{% block body %}
{% set total = pagination.total|default(articles|length) %}
<div class="wrap wrap--mid">

    {# ========= EN-TÊTE ========= #}
    <header class="j-head">
        <p class="ey">
            {% if activeCategory is defined %}Catégorie
            {% elseif activeTag is defined %}Tag
            {% else %}Archive{% endif %}
        </p>
        <h1>
            {% if activeCategory is defined %}{{ activeCategory.name }}
            {% elseif activeTag is defined %}#{{ activeTag.name }}
            {% else %}Le journal{% endif %}
        </h1>
        <p>
            {% if activeCategory is defined and activeCategory.description %}{{ activeCategory.description }}
            {% else %}Chaque entrée est une manip réelle, documentée de bout en bout. Les réussites comme les plantages.{% endif %}
        </p>
        <div class="j-count">
            {{ total }} entrée{{ total > 1 ? 's' : '' }} · Saison 01{% if totalPages > 1 %} · Page {{ currentPage }} / {{ totalPages }}{% endif %}
        </div>
    </header>

    {# ========= FILTRES ========= #}
    <div class="j-filters">
        <a class="j-chip {{ activeCategory is not defined and activeTag is not defined ? 'is-active' : '' }}" href="{{ path('app_blog_index') }}">Tout</a>
        {% for cat in categories %}
            <a class="j-chip {{ activeCategory is defined and activeCategory.id == cat.id ? 'is-active' : '' }}" href="{{ path('app_blog_category', {slug: cat.slug}) }}">{{ cat.name }}</a>
        {% endfor %}
    </div>

    {# ========= ARCHIVE ========= #}
    {% if articles|length > 0 %}
        <section class="j-arch">
            {% for a in articles %}
                <a class="j-item" href="{{ path('app_blog_show', {slug: a.slug}) }}">
                    <div class="idx">
                        {{ '%02d'|format(total - ((currentPage - 1) * articles|length) - loop.index0) }}
                        <small>{{ a.publishedAt ? a.publishedAt|date('d.m.y') : '—' }}</small>
                    </div>
                    <div>
                        <h2>{{ a.title }}</h2>
                        {% if a.excerpt %}<p class="ex">{{ a.excerpt }}</p>{% endif %}
                        <div class="tags">
                            <span>{{ a.category ? a.category.name|upper : 'LABS' }}</span>
                            <span class="t">{{ a.readingMinutes }} min</span>
                        </div>
                    </div>
                    <span class="go" aria-hidden="true">→</span>
                </a>
            {% endfor %}
        </section>

        {% if pagination is defined %}
            {% set _route = activeCategory is defined ? 'app_blog_category'
                         : activeTag is defined ? 'app_blog_tag'
                         : 'app_blog_index' %}
            {% set _routeParams = activeCategory is defined ? {slug: activeCategory.slug}
                               : activeTag is defined ? {slug: activeTag.slug}
                               : {} %}
            {% include 'components/_pagination.html.twig' with {
                pagination: pagination,
                route: _route,
                routeParams: _routeParams
            } only %}
        {% endif %}
    {% else %}
        <div style="padding:60px 0;text-align:center;color:var(--color-muted);">
            <p>Pas encore d'entrée ici.</p>
        </div>
    {% endif %}

    {% include 'components/_newsletter.html.twig' with {source: 'blog'} only %}

</div>
{% endblock %}
