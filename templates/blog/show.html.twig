{% extends 'base.html.twig' %}

{% block title %}{{ article.seoTitle ?: article.title }} · Privaris{% endblock %}
{% block description %}{{ article.seoDescription ?: article.excerpt }}{% endblock %}
{% block og_type %}article{% endblock %}
{% block og_image %}{% if article.coverImageUrl %}<meta property="og:image" content="{{ absolute_url(article.coverImageUrl|media_url('articles')) }}">{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block head_extra %}
    <meta property="article:published_time" content="{{ article.publishedAt|date('c') }}">
    {% if article.updatedAt %}<meta property="article:modified_time" content="{{ article.updatedAt|date('c') }}">{% endif %}
    {% if article.author %}<meta property="article:author" content="{{ article.author.displayName ?: article.author.email }}">{% endif %}
    {% if article.category %}<meta property="article:section" content="{{ article.category.name }}">{% endif %}
    {% for tag in article.tags %}<meta property="article:tag" content="{{ tag.name }}">{% endfor %}

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "NewsArticle",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ url('app_blog_show', {slug: article.slug}) }}" },
        "headline": {{ article.title|json_encode|raw }},
        "description": {{ (article.seoDescription ?: article.excerpt)|json_encode|raw }},
        "datePublished": "{{ article.publishedAt|date('c') }}",
        {% if article.updatedAt %}"dateModified": "{{ article.updatedAt|date('c') }}",{% endif %}
        "author": { "@type": "Person", "name": {{ (article.author.displayName ?: 'W.')|json_encode|raw }} },
        "publisher": { "@type": "Organization", "name": "Privaris", "logo": { "@type": "ImageObject", "url": "{{ absolute_url(asset('images/logo.svg')) }}" } },
        "inLanguage": "fr-FR"
        {% if article.category %},"articleSection": {{ article.category.name|json_encode|raw }}{% endif %}
        {% if article.tags|length > 0 %},"keywords": {{ article.tags|map(t => t.name)|join(', ')|json_encode|raw }}{% endif %}
        {% if article.coverImageUrl %},"image": "{{ absolute_url(article.coverImageUrl|media_url('articles')) }}"{% endif %}
    }
    </script>
{% endblock %}

{% block body %}
<article data-controller="reading-progress">
    {# Barre de progression de lecture (cyan, sous la barre haute) #}
    <div style="position:fixed;left:0;top:64px;right:0;height:2px;z-index:30;pointer-events:none;">
        <div data-reading-progress-target="bar" style="height:100%;width:0;background:var(--color-cyan);transition:width .1s ease-out;"></div>
    </div>

    {# ========= EN-TÊTE ========= #}
    <header class="art-head read">
        <a class="art-back" href="{{ path('app_blog_index') }}">← le journal</a>
        <div class="art-meta">
            {% if article.category %}
                <a class="cat" href="{{ path('app_blog_category', {slug: article.category.slug}) }}">{{ article.category.name }}</a>
            {% endif %}
            <span>{{ article.publishedAt ? article.publishedAt|date('d.m.Y') : '' }}</span>
            <span>{{ article.readingMinutes }} MIN</span>
        </div>
        <h1>{{ article.title }}</h1>
        {% if article.excerpt %}<p class="art-lede">{{ article.excerpt }}</p>{% endif %}
        <div class="art-sig">
            <span class="av">{{ (article.author ? (article.author.displayName ?: article.author.email) : 'W')|first|upper }}</span>
            <div><b>{{ article.author ? (article.author.displayName ?: 'W.') : 'W.' }}</b> &nbsp;<span>apprend la cyber en public</span></div>
        </div>
    </header>

    {# ========= COUVERTURE (si présente) ========= #}
    {% if article.coverImageUrl %}
        <div class="read" style="margin-bottom:8px;">
            <img src="{{ article.coverImageUrl|media_url('articles') }}" alt="{{ article.coverImageAlt ?: '' }}"
                 style="width:100%;height:auto;border-radius:14px;border:1px solid var(--color-line);"
                 fetchpriority="high" decoding="async">
        </div>
    {% endif %}

    {# ========= CORPS (HTML assaini) ========= #}
    <div class="art-body read">
        {{ article.content|sanitize_html('app.content') }}
    </div>

    {# ========= TAGS + NAV ========= #}
    <div class="read">
        {% if article.tags|length > 0 %}
            <div style="display:flex;flex-wrap:wrap;gap:8px;margin:8px 0 0;padding-top:24px;border-top:1px solid var(--color-line);">
                {% for tag in article.tags %}
                    <a href="{{ path('app_blog_tag', {slug: tag.slug}) }}" style="font-family:var(--font-mono);font-size:11px;color:var(--color-muted);border:1px solid var(--color-line);border-radius:999px;padding:5px 11px;text-decoration:none;">#{{ tag.name }}</a>
                {% endfor %}
            </div>
        {% endif %}

        {# Partage #}
        {% include 'components/_share.html.twig' with {
            url:   url('app_blog_show', {slug: article.slug}),
            title: article.title,
            text:  article.excerpt,
        } only %}

        <div class="art-next">
            <a href="{{ path('app_blog_index') }}">← le journal</a>
            <a href="{{ path('app_home') }}">↑ le radar</a>
        </div>
    </div>
</article>

{# ========= À LIRE AUSSI ========= #}
{% if related|length > 0 %}
    <div class="wrap wrap--mid">
        <div class="sec-head"><h2>À lire aussi</h2><a href="{{ path('app_blog_index') }}">tout le journal →</a></div>
        <div class="ledger">
            {% for r in related|filter(r => r.id != article.id)|slice(0, 4) %}
                <a class="led-row" href="{{ path('app_blog_show', {slug: r.slug}) }}">
                    <span class="num">{{ '%02d'|format(loop.index) }}</span>
                    <span class="date">{{ r.publishedAt ? r.publishedAt|date('d.m') : '—' }}</span>
                    <span class="ttl">{{ r.title }}</span>
                    <span class="cat">{{ r.category ? r.category.name|upper : 'LABS' }}</span>
                    <span class="rt">{{ r.readingMinutes }} min</span>
                </a>
            {% endfor %}
        </div>
    </div>
{% endif %}

<div class="wrap wrap--mid">
    {% include 'components/_newsletter.html.twig' with {source: 'article'} only %}
</div>
{% endblock %}
