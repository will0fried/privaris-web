<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url>
        <loc>{{ url('app_home') }}</loc>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>
    <url>
        <loc>{{ url('app_blog_index') }}</loc>
        <changefreq>daily</changefreq>
        <priority>0.9</priority>
    </url>
    <url>
        <loc>{{ url('app_podcast_index') }}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>
    <url>
        <loc>{{ url('app_sos_index') }}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>
    {% for s in sos|default([]) %}
    <url>
        <loc>{{ url('app_sos_show', {slug: s.slug}) }}</loc>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    {% endfor %}
    <url>
        <loc>{{ url('app_about') }}</loc>
        <priority>0.5</priority>
    </url>
    <url>
        <loc>{{ url('app_contact') }}</loc>
        <priority>0.5</priority>
    </url>

    {% for article in articles %}
    <url>
        <loc>{{ url('app_blog_show', {slug: article.slug}) }}</loc>
        <lastmod>{{ (article.updatedAt ?? article.publishedAt)|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    {% endfor %}

    {% for episode in episodes %}
    <url>
        <loc>{{ url('app_podcast_show', {slug: episode.slug}) }}</loc>
        <lastmod>{{ (episode.updatedAt ?? episode.publishedAt)|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    {% endfor %}

    {% for cat in categories %}
    <url>
        <loc>{{ url('app_blog_category', {slug: cat.slug}) }}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.6</priority>
    </url>
    {% endfor %}

    {% for tag in tags %}
    <url>
        <loc>{{ url('app_blog_tag', {slug: tag.slug}) }}</loc>
        <changefreq>monthly</changefreq>
        <priority>0.4</priority>
    </url>
    {% endfor %}
</urlset>
