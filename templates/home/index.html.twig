{% extends 'base.html.twig' %}

{% block title %}Privaris · Mon Labo — apprendre la cyber en public{% endblock %}
{% block description %}Le carnet de labo de W. : j'apprends la cybersécurité en la pratiquant. Je monte un lab, je l'attaque, je le défends, je documente tout, surtout les plantages.{% endblock %}

{% block body %}
{% set detections = (featured ? [featured] : [])|merge(rest) %}
<div class="wrap">

    {# ===================== HÉROS — radar + accroche ===================== #}
    <section class="home-hero">
        <div>
            <p class="ey">Carnet de labo · cyber en public</p>
            <h1>Casser pour<br>comprendre.<br><span class="o">Défendre pour de vrai.</span></h1>
            <p class="lede">Salarié le jour, en Master de cybersécurité le soir. Je monte un lab, je l'attaque, je le défends. Je documente tout, surtout les plantages.</p>
            <div class="home-stats">
                <div class="stat"><div class="n">{{ '%02d'|format(detections|length) }}</div><div class="l">manips publiées</div></div>
                <div class="stat"><div class="n">01</div><div class="l">labo maison</div></div>
                <div class="stat red"><div class="n">S01</div><div class="l">saison en cours</div></div>
            </div>
        </div>

        <div class="home-scope">
            {# RADAR « Mon Labo » — détections = entrées. Positionnement géré par radar_controller.js. #}
            <div class="radar" data-controller="radar" role="group" aria-label="Radar des détections — le journal">
                <svg class="radar__rings" viewBox="0 0 100 100" aria-hidden="true">
                    <g fill="none" stroke="#FFFFFF">
                        <circle cx="50" cy="50" r="46" stroke-width=".25" opacity=".16"/>
                        <circle cx="50" cy="50" r="34" stroke-width=".25" opacity=".13"/>
                        <circle cx="50" cy="50" r="22" stroke-width=".25" opacity=".13"/>
                        <circle cx="50" cy="50" r="10" stroke-width=".25" opacity=".16"/>
                        <line x1="50" y1="3" x2="50" y2="97" stroke-width=".2" opacity=".1"/>
                        <line x1="3" y1="50" x2="97" y2="50" stroke-width=".2" opacity=".1"/>
                    </g>
                </svg>
                <div class="radar__sweep" aria-hidden="true"></div>
                <div class="radar__core" aria-hidden="true"><span class="radar__core-dot"></span><span class="radar__core-label">Radar actif</span></div>

                {% for a in detections|slice(0, 8) %}
                    <a class="radar__blip{{ loop.first ? ' is-live' : '' }}"
                       data-radar-target="blip"
                       href="{{ path('app_blog_show', {slug: a.slug}) }}">
                        <span class="radar__label"><span class="radar__label-kind">{{ a.category ? a.category.name : 'Manip' }}</span>{{ a.title }}</span>
                    </a>
                {% else %}
                    <a class="radar__blip is-soon" data-radar-target="blip" href="#newsletter">
                        <span class="radar__label">Première détection à venir</span>
                    </a>
                {% endfor %}
            </div>
            <p class="radar__hint">Survole une détection · clique pour lire</p>
        </div>
    </section>

    {# ===================== REGISTRE — dernières entrées ===================== #}
    {% if detections|length > 0 %}
    <section>
        <div class="sec-head">
            <h2>Dernières entrées</h2>
            <a href="{{ path('app_blog_index') }}">tout le journal →</a>
        </div>
        <div class="ledger">
            {% for a in detections|slice(0, 6) %}
                <a class="led-row" href="{{ path('app_blog_show', {slug: a.slug}) }}">
                    <span class="num">{{ '%02d'|format(loop.revindex) }}</span>
                    <span class="date">{{ a.publishedAt ? a.publishedAt|date('d.m') : '—' }}</span>
                    <span class="ttl">{{ a.title }}</span>
                    <span class="cat">{{ a.category ? a.category.name|upper : 'LABS' }}</span>
                    <span class="rt">{{ a.readingMinutes }} min</span>
                </a>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {# ===================== RELEVÉ — newsletter (Brevo, CSRF préservés) ===================== #}
    <section id="newsletter" class="relay">
        <div>
            <p class="k">Le relevé du dimanche</p>
            <h3>Une entrée par semaine, dans ta boîte mail.</h3>
            <p>La manip du dimanche, le plantage qui va avec. Zéro pub, zéro traceur.</p>
        </div>
        <div>
            <form class="relay__form"
                  data-controller="newsletter"
                  data-newsletter-endpoint-value="{{ path('app_newsletter_subscribe') }}"
                  data-newsletter-csrf-value="{{ csrf_token('newsletter_subscribe') }}"
                  data-action="submit->newsletter#submit">
                <input type="email" name="email" required autocomplete="email"
                       placeholder="ton@email.fr"
                       data-newsletter-target="email"
                       aria-label="Ton adresse email">
                <input type="hidden" name="source" value="home">
                <button type="submit" class="pv-btn" data-newsletter-target="submitBtn">S'abonner</button>
            </form>
            <p class="relay__msg" data-newsletter-target="message" aria-live="polite"></p>
        </div>
    </section>

</div>
{% endblock %}
