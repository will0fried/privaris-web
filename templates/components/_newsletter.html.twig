{#
    Bloc newsletter — réutilisé sur journal, à-propos, podcast.
    Style « relevé » sombre. Ancre #newsletter pour le lien du header.
    Contrôleur Stimulus newsletter + CSRF préservés.
#}
<section id="newsletter" class="relay">
    <div>
        <p class="k">Le relevé du dimanche</p>
        <h3>Une entrée par semaine, dans ta boîte mail.</h3>
        <p>La manip du dimanche, le plantage qui va avec. Zéro pub, zéro traceur, désinscription en un clic.</p>
    </div>
    <div>
        <form class="relay__form"
              data-controller="newsletter"
              data-newsletter-endpoint-value="{{ path('app_newsletter_subscribe') }}"
              data-newsletter-csrf-value="{{ csrf_token('newsletter_subscribe') }}"
              data-action="submit->newsletter#submit">
            <input type="email" name="email" required autocomplete="email"
                   placeholder="ton@email.fr"
                   data-newsletter-target="email"
                   aria-label="Ton adresse email">
            <input type="hidden" name="source" value="{{ source|default('site') }}">
            <button type="submit" class="pv-btn" data-newsletter-target="submitBtn">S'abonner</button>
        </form>
        <p class="relay__msg" data-newsletter-target="message" aria-live="polite"></p>
        <p style="font-family:var(--font-mono);font-size:10.5px;color:var(--color-dim);letter-spacing:.04em;margin:12px 0 0;">
            En t'abonnant tu acceptes la <a href="{{ path('app_privacy') }}" style="color:var(--color-muted);text-decoration:underline;">politique de confidentialité</a>.
        </p>
    </div>
</section>
