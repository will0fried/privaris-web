{#
    Composant Partage — Privaris
    ----------------------------
    Paramètres :
      url   : URL absolue de la ressource (article, épisode, page SOS…)
      title : titre à utiliser dans les messages pré-remplis
      text  : optionnel — description courte (sinon : titre)
      label : optionnel — eyebrow au-dessus des boutons (défaut "Partager")

    Choix éditoriaux :
      - Aucun SDK tiers : que des URLs d'intent. Pas de Facebook Pixel, pas de
        LinkedIn Insight, pas de Twitter widget. Cohérent avec le positionnement
        vie privée du média.
      - Web Share API natif (Stimulus) : sur mobile, ouvre le menu système iOS/
        Android. L'utilisateur partage où il veut (Signal, Telegram, SMS, etc.).
        Bouton invisible sur desktop (le contrôleur le cache si non supporté).
      - WhatsApp : compatible mobile (ouvre l'app) et desktop (web.whatsapp.com).
#}
{% set _label = label|default('Partager') %}
{% set _text  = text|default(title) %}
{% set _url   = url %}
{% set _title = title %}

{# Pré-encodages réutilisés #}
{% set _u  = _url|url_encode %}
{% set _t  = _title|url_encode %}
{% set _tx = _text|url_encode %}

<div class="share-block" data-controller="web-share"
     data-web-share-url-value="{{ _url }}"
     data-web-share-title-value="{{ _title }}"
     data-web-share-text-value="{{ _text }}">
    <p class="text-xs uppercase tracking-[0.2em] text-fog mb-3">{{ _label }}</p>

    <div class="flex flex-wrap gap-2">
        {# ---- Bouton natif (Web Share API) — caché par défaut, révélé si supporté ---- #}
        <button type="button"
                class="share-btn share-btn--native is-hidden"
                data-web-share-target="nativeBtn"
                data-action="click->web-share#share"
                aria-label="Ouvrir le menu de partage natif">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                <polyline points="16 6 12 2 8 6"/>
                <line x1="12" y1="2" x2="12" y2="15"/>
            </svg>
            <span>Partager</span>
        </button>

        {# ---- Facebook ---- #}
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ _u }}"
           target="_blank" rel="noopener noreferrer"
           class="share-btn"
           aria-label="Partager sur Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M9 8H6v4h3v12h5V12h3.642L18 8h-4V6.333C14 5.378 14.192 5 15.115 5H18V0h-3.808C10.596 0 9 1.583 9 4.615V8z"/>
            </svg>
            <span>Facebook</span>
        </a>

        {# ---- LinkedIn ---- #}
        <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ _u }}"
           target="_blank" rel="noopener noreferrer"
           class="share-btn"
           aria-label="Partager sur LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
            <span>LinkedIn</span>
        </a>

        {# ---- WhatsApp ---- #}
        {# wa.me ouvre l'app sur mobile ET web.whatsapp.com sur desktop. Le texte
           pré-rempli inclut le titre + l'URL pour que le destinataire voie un aperçu. #}
        <a href="https://wa.me/?text={{ _t }}%20{{ _u }}"
           target="_blank" rel="noopener noreferrer"
           class="share-btn"
           aria-label="Partager sur WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
            </svg>
            <span>WhatsApp</span>
        </a>

        {# ---- X / Twitter ---- #}
        <a href="https://twitter.com/intent/tweet?url={{ _u }}&text={{ _t }}"
           target="_blank" rel="noopener noreferrer"
           class="share-btn"
           aria-label="Partager sur X">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span>X</span>
        </a>

        {# ---- Email ---- #}
        <a href="mailto:?subject={{ _t }}&body={{ _tx }}%0D%0A%0D%0A{{ _u }}"
           class="share-btn"
           aria-label="Partager par email">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-10 5L2 7"/>
            </svg>
            <span>Email</span>
        </a>

        {# ---- Copier le lien ---- #}
        <button type="button"
                class="share-btn copy-link-btn"
                data-controller="copy-link"
                data-copy-link-url-value="{{ _url }}"
                data-copy-link-label-value="Copier"
                data-copy-link-success-label-value="✓ Copié"
                data-action="click->copy-link#copy"
                aria-label="Copier le lien">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            <span data-copy-link-target="label">Copier</span>
        </button>
    </div>
</div>
