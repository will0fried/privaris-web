{#
    Cover placeholder éditorial — signal radar + grille cyber.
    Paramètres :
      seed  : int  — sert à varier le pattern (décalage, rotation)
      large : bool — variante plus dense pour les feature articles
#}
{% set seed = seed|default(1) %}
{% set variant = (seed % 4) %}

<div class="cover-placeholder cover-placeholder--variant-{{ variant }}{% if large is defined and large %} cover-placeholder--large{% endif %}">
    {# Grille signal en fond — très discrète #}
    <svg class="cover-placeholder__grid" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" aria-hidden="true">
        <defs>
            <pattern id="cp-grid-{{ seed }}" width="32" height="32" patternUnits="userSpaceOnUse">
                <path d="M 32 0 L 0 0 0 32" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.18"/>
            </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#cp-grid-{{ seed }})"/>
    </svg>

    {# Signature radar — concentric rings + crosshair, motif brand Privaris #}
    <svg class="cover-placeholder__mark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" aria-hidden="true">
        {# Cercles concentriques — opacité dégradée #}
        <circle cx="60" cy="60" r="54" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.18"/>
        <circle cx="60" cy="60" r="40" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.28"/>
        <circle cx="60" cy="60" r="26" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.45"/>
        <circle cx="60" cy="60" r="12" fill="none" stroke="currentColor" stroke-width="1" opacity="0.7"/>
        <circle cx="60" cy="60" r="3.5" fill="currentColor" opacity="1"/>

        {# Crosshair fin #}
        <line x1="60" y1="6"   x2="60" y2="114" stroke="currentColor" stroke-width="0.6" opacity="0.35"/>
        <line x1="6"  y1="60"  x2="114" y2="60" stroke="currentColor" stroke-width="0.6" opacity="0.35"/>

        {# Signal point — petit dot décalé, donne une "position" variable selon le seed #}
        {% set sx = 60 + ((seed * 9) % 42) - 12 %}
        {% set sy = 60 - ((seed * 13) % 38) - 8 %}
        <circle cx="{{ sx }}" cy="{{ sy }}" r="2.5" fill="currentColor"/>
        <circle cx="{{ sx }}" cy="{{ sy }}" r="6" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.4"/>
    </svg>

    {# Code monospace décoratif bas-gauche — identifiant éditorial #}
    <p class="cover-placeholder__code" aria-hidden="true">
        {{ '%03d'|format((seed * 7) % 999 + 1) }}
    </p>
    <p class="cover-placeholder__label" aria-hidden="true">PRIVARIS · SIGNAL</p>
</div>
