{#
    Composant pagination — Privaris (sombre)
    Paramètres : pagination {page, pages, total}, route, routeParams
#}
{% set page  = pagination.page|default(1) %}
{% set pages = pagination.pages|default(1) %}
{% set routeParams = routeParams|default({}) %}

{% if pages > 1 %}
    <nav class="pager" aria-label="Pagination">
        <p class="pager__count">Page {{ page }} / {{ pages }} · {{ pagination.total }} entrée{{ pagination.total > 1 ? 's' : '' }}</p>

        <ul class="pager__links">
            <li>
                {% if page > 1 %}
                    <a href="{{ path(route, routeParams|merge({page: page - 1})) }}" rel="prev" aria-label="Page précédente">←</a>
                {% else %}
                    <span class="pg is-disabled" aria-disabled="true">←</span>
                {% endif %}
            </li>

            {% set numbers = [] %}
            {% for p in 1..pages %}
                {% if p == 1 or p == pages or (p >= page - 1 and p <= page + 1) %}
                    {% set numbers = numbers|merge([p]) %}
                {% endif %}
            {% endfor %}

            {% set prev = 0 %}
            {% for p in numbers %}
                {% if p - prev > 1 %}<li class="dots" aria-hidden="true">…</li>{% endif %}
                <li>
                    {% if p == page %}
                        <span class="pg is-current" aria-current="page">{{ p }}</span>
                    {% else %}
                        <a href="{{ path(route, routeParams|merge({page: p})) }}">{{ p }}</a>
                    {% endif %}
                </li>
                {% set prev = p %}
            {% endfor %}

            <li>
                {% if page < pages %}
                    <a href="{{ path(route, routeParams|merge({page: page + 1})) }}" rel="next" aria-label="Page suivante">→</a>
                {% else %}
                    <span class="pg is-disabled" aria-disabled="true">→</span>
                {% endif %}
            </li>
        </ul>
    </nav>
{% endif %}
