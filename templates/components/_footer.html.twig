{% set route = app.request.attributes.get('_route') %}

<footer class="bg-bone border-t border-mist">

    {# Logo seul, simple. Pas de bandeau "engagements". #}
    <div class="container-wide pt-16 md:pt-20 pb-10">
        <div class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                <circle cx="16" cy="16" r="13" stroke="{{ brand_navy }}" stroke-width="1.5"/>
                <circle cx="16" cy="16" r="8"  stroke="{{ brand_navy }}" stroke-width="1.5"/>
                <circle cx="16" cy="16" r="3"  fill="{{ brand_navy }}"/>
            </svg>
            <span class="font-mono font-bold tracking-tight text-ink">privaris<span class="text-navy">.fr</span></span>
        </div>
        <p class="j-stamp mt-3">apprendre la cyber en public</p>
    </div>

    {# ========= Colonnes de navigation ========= #}
    <div class="border-t border-mist">
        <div class="container-wide py-12 grid gap-10 md:grid-cols-12">

            <div class="md:col-span-4">
                <p class="eyebrow">Contenu</p>
                <ul class="space-y-2.5 text-sm">
                    <li><a href="{{ path('app_blog_index') }}" class="text-ink hover:text-navy no-underline">Journal</a></li>
                    <li><a href="{{ path('app_search') }}" class="text-ink hover:text-navy no-underline">Rechercher</a></li>
                </ul>
            </div>

            <div class="md:col-span-4">
                <p class="eyebrow">Site</p>
                <ul class="space-y-2.5 text-sm">
                    <li><a href="{{ path('app_about') }}" class="text-ink hover:text-navy no-underline">À propos</a></li>
                    <li><a href="{{ path('app_contact') }}" class="text-ink hover:text-navy no-underline">Contact</a></li>
                    <li><a href="#newsletter" class="text-ink hover:text-navy no-underline">Newsletter</a></li>
                </ul>
            </div>

            <div class="md:col-span-4">
                <p class="eyebrow">Légal</p>
                <ul class="space-y-2.5 text-sm">
                    <li><a href="{{ path('app_legal') }}" class="text-ink hover:text-navy no-underline">Mentions légales</a></li>
                    <li><a href="{{ path('app_privacy') }}" class="text-ink hover:text-navy no-underline">Confidentialité</a></li>
                </ul>
            </div>
        </div>
    </div>

    {# Baseline fine, pas de version, juste copyright et RSS. #}
    <div class="border-t border-mist">
        <div class="container-wide py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-fog">
            <p>© {{ "now"|date("Y") }} Privaris</p>
            <a href="{{ url('app_podcast_feed') }}" class="text-fog hover:text-navy no-underline font-mono text-[10px] uppercase tracking-[0.15em]">RSS</a>
        </div>
    </div>
</footer>
