{% set route = app.request.attributes.get('_route') %}
{% set has_alert = app.request.attributes.get('_has_alert', false) %}

<header class="site-top">
    <div class="wrap site-top__in">
        <a href="{{ path('app_home') }}" class="site-brand" aria-label="Privaris, retour à l'accueil">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-linecap="round" aria-hidden="true">
                <circle cx="32" cy="32" r="22" stroke-width="1.4" opacity=".4"/>
                <circle cx="32" cy="32" r="13" stroke-width="1.4" opacity=".6"/>
                <circle cx="32" cy="32" r="5" stroke-width="2"/>
                <circle cx="44" cy="22" r="2.4" fill="#E5484D" stroke="none"/>
            </svg>
            PRIVARIS
        </a>

        <nav class="site-nav" aria-label="Menu principal">
            <a href="{{ path('app_blog_index') }}" class="{{ route starts with 'app_blog' ? 'is-active' : '' }}">Journal</a>
            <a href="{{ path('app_about') }}" class="{{ route == 'app_about' ? 'is-active' : '' }}">À propos</a>
            <a href="{{ path('app_contact') }}" class="{{ route == 'app_contact' ? 'is-active' : '' }}">Contact</a>
            <a href="{{ path('app_search') }}" class="{{ route == 'app_search' ? 'is-active' : '' }}" aria-label="Rechercher" title="Rechercher">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            </a>
            <span class="site-live" aria-hidden="true"><i></i> {{ has_alert ? 'ALERTE' : 'RADAR ACTIF' }}</span>
        </nav>

        <button class="site-burger" data-controller="mobile-menu" data-action="click->mobile-menu#toggle" aria-label="Menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
        </button>
    </div>

    <div id="mobile-menu" class="site-mobile hidden" role="dialog" aria-modal="true" aria-label="Menu principal">
        <div class="wrap">
            <a href="{{ path('app_blog_index') }}">Journal</a>
            <a href="{{ path('app_about') }}">À propos</a>
            <a href="{{ path('app_contact') }}">Contact</a>
            <a href="{{ path('app_search') }}">Rechercher</a>
        </div>
    </div>
</header>
