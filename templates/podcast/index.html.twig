{% extends 'base.html.twig' %}

{% block title %}Podcast Privaris · le labo, raconté à voix haute{% endblock %}
{% block description %}Bientôt : je raconte mes manips à voix haute, en format court. En attendant, tout est dans le journal écrit.{% endblock %}

{% block head_extra %}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "PodcastSeries",
        "name": "Privaris",
        "url": "{{ url('app_podcast_index') }}",
        "description": "Le podcast de Privaris · Mon Labo : raconter une manip de cybersécurité à voix haute, en format court.",
        "webFeed": "{{ url('app_podcast_feed') }}",
        "inLanguage": "fr-FR",
        "author": { "@type": "Person", "name": "W." },
        "publisher": { "@type": "Organization", "name": "Privaris" }
    }
    </script>
{% endblock %}

{% block body %}
<div class="wrap wrap--mid">

    <header class="ab-hero">
        <p class="ey">Le podcast · bientôt</p>
        <h1>Le labo, à voix haute.</h1>
        <p class="ab-lede">L'idée : raconter une manip, ce que j'ai tenté, ce qui a cassé, ce que j'en ai tiré, en format court. Le podcast arrive ; pour l'instant, tout est dans le journal écrit.</p>
        {% if episodes|length > 0 %}
            <div class="ab-meta">
                <span><a href="{{ url('app_podcast_feed') }}" style="color:var(--color-cyan);">RSS</a></span>
                <span>Apple Podcasts</span>
                <span>Spotify</span>
            </div>
        {% endif %}
    </header>

    {% if episodes|length > 0 %}
        <section>
            <div class="sec-head"><h2>Les épisodes</h2></div>
            <div>
                {% for episode in episodes %}
                    {% include 'components/_episode_row.html.twig' with {episode: episode} only %}
                {% endfor %}
            </div>
        </section>
    {% else %}
        <section>
            <p class="kicker">En préparation · Saison 01</p>
            <p style="color:var(--color-muted);font-size:17px;line-height:1.6;max-width:54ch;margin:0 0 30px;">
                Cinq épisodes sont écrits, prêts à passer au micro. La saison démarre dès que le studio est calé.
            </p>
            <ol class="prog">
                <li><span class="pn">01</span><span class="pt">Le rançongiciel, c'est quoi en vrai ?</span><span class="pd">3:12</span></li>
                <li><span class="pn">02</span><span class="pt">Le phishing en 3 minutes</span><span class="pd">3:45</span></li>
                <li><span class="pn">03</span><span class="pt">Pourquoi la double authentification vaut tout</span><span class="pd">3:30</span></li>
                <li><span class="pn">04</span><span class="pt">Protéger ses enfants en ligne</span><span class="pd">4:20</span></li>
                <li><span class="pn">05</span><span class="pt">Deepfakes au téléphone</span><span class="pd">3:50</span></li>
            </ol>
            <div class="cta">
                <a class="pv-btn" href="#newsletter">Être prévenu du lancement</a>
                <a class="pv-btn pv-btn--ghost" href="{{ path('app_blog_index') }}">Lire le journal</a>
            </div>
        </section>
    {% endif %}

    {% include 'components/_newsletter.html.twig' with {source: 'podcast'} only %}
</div>
{% endblock %}
