{% extends 'base.html.twig' %}

{% block title %}{{ episode.title }} · Podcast Privaris{% endblock %}
{% block description %}{{ episode.excerpt }}{% endblock %}
{% block og_type %}article{% endblock %}

{% block head_extra %}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "PodcastEpisode",
        "url": "{{ url('app_podcast_show', {slug: episode.slug}) }}",
        "name": {{ episode.title|json_encode|raw }},
        "description": {{ episode.excerpt|json_encode|raw }},
        "datePublished": "{{ episode.publishedAt|date('c') }}",
        "duration": "{{ episode.duration }}",
        "episodeNumber": {{ episode.number }},
        "seasonNumber": {{ episode.season|replace({'S': ''}) }},
        "inLanguage": "fr-FR",
        "associatedMedia": { "@type": "MediaObject", "contentUrl": "{{ episode.audioUrl }}", "encodingFormat": "{{ episode.audioMimeType }}" },
        "partOfSeries": { "@type": "PodcastSeries", "name": "Privaris", "url": "{{ url('app_podcast_index') }}", "webFeed": "{{ url('app_podcast_feed') }}" }
    }
    </script>
{% endblock %}

{% block body %}
<article>
    <header class="art-head read">
        <a class="art-back" href="{{ path('app_podcast_index') }}">← le podcast</a>
        <div class="art-meta">
            <span class="cat">{{ episode.season }} · ÉP {{ episode.number }}</span>
            <span>{{ episode.publishedAt ? episode.publishedAt|date('d.m.Y') : '' }}</span>
            <span>{{ episode.duration }}</span>
        </div>
        <h1>{{ episode.title }}</h1>
        {% if episode.excerpt %}<p class="art-lede">{{ episode.excerpt }}</p>{% endif %}
    </header>

    {# ========= LECTEUR AUDIO ========= #}
    <div class="read">
        <div data-controller="audio-player" class="audio-player">
            <audio data-audio-player-target="audio" src="{{ episode.audioUrl }}" preload="metadata" type="{{ episode.audioMimeType }}"></audio>
            <div style="display:flex;align-items:center;gap:18px;">
                <button data-audio-player-target="playBtn" data-action="click->audio-player#toggle" class="audio-player__btn" aria-label="Lecture / pause">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                </button>
                <div style="flex:1;min-width:0;">
                    <p class="mono" style="font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--color-dim);margin:0 0 8px;">À l'écoute · Épisode {{ episode.number }}</p>
                    <div style="display:flex;align-items:center;gap:12px;">
                        <span data-audio-player-target="currentTime" class="mono" style="font-size:11px;color:var(--color-dim);width:38px;">0:00</span>
                        <input type="range" min="0" max="100" value="0" step="0.1" data-audio-player-target="seek" data-action="input->audio-player#seek" class="audio-player__seek" style="flex:1;" aria-label="Progression">
                        <span data-audio-player-target="duration" class="mono" style="font-size:11px;color:var(--color-dim);width:38px;text-align:right;">{{ episode.duration }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ========= NOTES ========= #}
    <div class="art-body read">
        {{ episode.description|sanitize_html('app.content') }}
    </div>

    {% if episode.transcript %}
        <div class="read">
            <details style="border-top:1px solid var(--color-line);padding-top:24px;">
                <summary style="cursor:pointer;color:var(--color-cyan);font-family:var(--font-mono);font-size:13px;">Transcription complète</summary>
                <div class="art-body" style="padding-top:18px;">{{ episode.transcript|sanitize_html('app.content') }}</div>
            </details>
        </div>
    {% endif %}

    <div class="read">
        {% if episode.article %}
            <a href="{{ path('app_blog_show', {slug: episode.article.slug}) }}" style="display:block;border:1px solid var(--color-line);border-radius:14px;padding:22px;margin-top:8px;text-decoration:none;background:linear-gradient(180deg,var(--color-panel),transparent);">
                <p style="font-family:var(--font-mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--color-cyan);margin:0 0 6px;">Entrée associée</p>
                <p style="font-weight:600;color:var(--color-text);margin:0;">{{ episode.article.title }}</p>
            </a>
        {% endif %}

        {% include 'components/_share.html.twig' with {
            url:   url('app_podcast_show', {slug: episode.slug}),
            title: episode.title,
            text:  episode.excerpt,
            label: 'Partager',
        } only %}

        <div class="art-next">
            <a href="{{ path('app_podcast_index') }}">← le podcast</a>
            <a href="{{ path('app_home') }}">↑ le radar</a>
        </div>
    </div>
</article>

{% if related|length > 0 %}
    <div class="wrap wrap--mid">
        <div class="sec-head"><h2>Autres épisodes</h2></div>
        <div>
            {% for r in related|filter(r => r.id != episode.id)|slice(0, 4) %}
                {% include 'components/_episode_row.html.twig' with {episode: r} only %}
            {% endfor %}
        </div>
    </div>
{% endif %}

<div class="wrap wrap--mid">
    {% include 'components/_newsletter.html.twig' with {source: 'episode'} only %}
</div>
{% endblock %}
