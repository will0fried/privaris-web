# Privaris · Mon Labo — service statique
# (ancien .htaccess Symfony conservé dans .htaccess.symfony.bak)
# Aucune redirection ici -> aucune boucle possible.

DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Toujours servir la page du labo (réécriture interne, pas de redirection)
  RewriteRule ^(index\.php)?$ index.html [L]
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>
