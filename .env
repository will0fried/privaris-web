# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING_IN_LOCAL
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# PlanetHoster : mysql://user:pass@localhost:3306/dbname?serverVersion=8.0.39&charset=utf8mb4
DATABASE_URL="mysql://root:root@127.0.0.1:8889/privaris?serverVersion=8.0.35&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# PlanetHoster : smtp://user:pass@mail.votredomaine.com:587
MAILER_DSN=null://null
MAILER_FROM_EMAIL=contact@privaris.fr
MAILER_FROM_NAME="Privaris"
###< symfony/mailer ###

###> privaris/newsletter ###
# Brevo API key — créer sur https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_LIST_ID=
NEWSLETTER_DOUBLE_OPT_IN=1
###< privaris/newsletter ###

###> privaris/podcast ###
PODCAST_TITLE="Privaris"
PODCAST_SUBTITLE="Cybersécurité, 3 minutes chrono."
PODCAST_DESCRIPTION="Le podcast qui parle cybersécurité en français, sans jargon. Pour vous, vos proches, votre famille."
PODCAST_AUTHOR="Privaris"
PODCAST_EMAIL=contact@privaris.fr
PODCAST_LANGUAGE=fr-FR
PODCAST_CATEGORY="Technology"
PODCAST_EXPLICIT=false
PODCAST_COVER_URL=/images/podcast-cover.png
###< privaris/podcast ###

###> privaris/security ###
# Rate limiting : nb de tentatives de login par minute, par IP
LOGIN_RATE_LIMIT=5
# Trusted proxies (PlanetHoster CDN, Cloudflare...)
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS='^(localhost|127\.0\.0\.1|privaris\.fr|www\.privaris\.fr)$'
###< privaris/security ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/lock ###
# Choose one of the stores below
# postgresql+advisory://db_user:db_password@localhost/db_name
LOCK_DSN=flock
###< symfony/lock ###
