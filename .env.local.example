# =============================================================================
#  Privaris · variables d'environnement locales
# =============================================================================
#
# Ce fichier est un MODÈLE. Il est versionné dans git (donc public).
# Les VRAIES valeurs vont dans `.env.local`, qui n'est PAS versionné.
#
# Étapes :
#   1. cp .env.local.example .env.local
#   2. Remplir chaque ligne avec tes vraies valeurs.
#   3. Ne jamais commit .env.local ni partager son contenu (chat, mail, etc.).
#
# =============================================================================

# ------------------------------------------------------------- App / Symfony

# `dev` en local, `prod` en production.
APP_ENV=dev

# Clé secrète Symfony, 32 caractères hex aléatoires.
# Pour générer une nouvelle clé :
#   php -r "echo bin2hex(random_bytes(16)) . PHP_EOL;"
APP_SECRET=replace_me_with_32_hex_chars

# `0` en prod, `1` en local pour debug.
APP_DEBUG=1

# URL absolue du site (utilisée par les commandes CLI pour générer des liens).
# En dev : http://localhost:8000
# En prod : https://privaris.fr
DEFAULT_URI=http://localhost:8000

# ------------------------------------------------------------- Base de données

# Format Doctrine. En local (MAMP) : root/root sur le port 8889.
# En prod PlanetHoster : créer une DB dans N0C, récupérer user/pass/host/db.
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DBNAME?serverVersion=8.0.39&charset=utf8mb4"

# ------------------------------------------------------------- Mailer

# Brevo (recommandé pour newsletter et transactionnel).
# Récupérer la clé SMTP dans Brevo : Settings → SMTP & API → SMTP.
MAILER_DSN=brevo+smtp://USER@privaris.fr:SMTP_KEY@default

# Adresse expéditeur (doit être validée dans Brevo, DKIM/SPF/DMARC OK).
MAILER_FROM_EMAIL=newsletter@privaris.fr
MAILER_FROM_NAME=Privaris

# ------------------------------------------------------------- Brevo API

# Clé API Brevo (Settings → SMTP & API → API keys). Différente de la clé SMTP.
BREVO_API_KEY=xkeysib-REPLACE_ME

# ID de la liste de diffusion principale dans Brevo.
# Visible dans Contacts → Lists → l'ID est dans l'URL.
BREVO_LIST_ID=1

# Double opt-in newsletter (recommandé, conforme RGPD).
NEWSLETTER_DOUBLE_OPT_IN=1

# ------------------------------------------------------------- Sécurité

LOGIN_RATE_LIMIT=5

# Trusted proxies (Cloudflare ou autre CDN devant le site).
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR

# Domaines autorisés pour la génération d'URL Symfony.
TRUSTED_HOSTS='^(localhost|127\.0\.0\.1|privaris\.fr|www\.privaris\.fr)$'

# ------------------------------------------------------------- Admin initial

# Mot de passe initial du compte admin (créé par les fixtures).
# Si vide, un mot de passe aléatoire est généré et affiché en sortie de fixtures.
# IMPORTANT : à changer à la première connexion EasyAdmin.
APP_ADMIN_INITIAL_PASSWORD=

# ------------------------------------------------------------- Lock

LOCK_DSN=flock
